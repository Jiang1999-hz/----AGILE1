{
  "name": "juku-ai-cloud",
  "version": "0.1.0",
  "private": true,
  "description": "Juku AI Cloud demo with student S1 backend",
  "scripts": {
    "dev": "node ./server.js",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "node ./scripts/import-question-bank.js ./data/question-bank.json",
    "db:test": "node ./scripts/test-db-connection.js",
    "pipeline:import": "node ./scripts/import-question-bank.js ./data/sequence-question-bank.json"
  },
  "dependencies": {
    "@prisma/client": "^6.6.0",
    "dotenv": "^16.4.7",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "prisma": "^6.6.0"
  }
}
