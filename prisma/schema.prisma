generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Student {
  id              Int              @id @default(autoincrement())
  name            String
  grade           String
  groupName       String
  goal            String
  score           Int
  attendance      Int
  risk            String
  summary         String
  parentNote      String
  teacherFeedback String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  abilities       StudentAbility[]
  quizSubmissions QuizSubmission[]
  homeworks       Homework[]
  messages        Message[]
  enrollments     StudentCourse[]
}

model Course {
  id               String          @id
  title            String
  subject          String
  totalLessons     Int
  completedLessons Int
  nextLessonAt     String
  schedule         String
  teacherName      String
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  lessons          Lesson[]
  enrollments      StudentCourse[]
}

model StudentCourse {
  id        Int      @id @default(autoincrement())
  studentId Int
  courseId  String
  createdAt DateTime @default(now())
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([studentId, courseId])
}

model Lesson {
  id             String   @id
  courseId       String
  dateLabel      String
  weekday        String
  timeLabel      String
  title          String
  ppt            String
  notes          String
  completion     Int
  understanding  Int
  homeworkStatus String
  requiresHomework Boolean @default(true)
  wrongCount     Int
  metrics        Json
  highlights     Json
  mistakes       Json
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  course         Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  homeworks      Homework[]
}

model StudentAbility {
  id        Int      @id @default(autoincrement())
  studentId Int
  label     String
  value     Int
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, label])
}

model QuizSubmission {
  id        Int      @id @default(autoincrement())
  studentId Int
  name      String
  score     Int
  note      String
  dateLabel String
  createdAt DateTime @default(now())
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model Question {
  id            String                    @id
  subjectId     String
  topicId       String
  levelId       String
  abilityIndex  Int
  type          String
  prompt        String
  answer        String
  active        Boolean                   @default(true)
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt
  subject       QuestionSubject           @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  topic         QuestionTopic             @relation(fields: [subjectId, topicId], references: [subjectId, id], onDelete: Cascade)
  choices       QuestionChoice[]
  explanation   QuestionExplanation?
}

model QuestionSubject {
  id          String           @id
  label       String
  shortLabel  String
  accent      String
  description String
  mapTitle    String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  topics      QuestionTopic[]
  questions   Question[]
}

model QuestionTopic {
  id          String
  subjectId   String
  label       String
  summary     String
  keywords    Json
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  subject     QuestionSubject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  questions   Question[]

  @@id([subjectId, id])
  @@unique([subjectId, label])
}

model QuestionChoice {
  id          Int       @id @default(autoincrement())
  questionId  String
  label       String
  sortOrder   Int
  createdAt   DateTime  @default(now())
  question    Question  @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([questionId, sortOrder])
}

model QuestionExplanation {
  id           Int                         @id @default(autoincrement())
  questionId   String                      @unique
  assetType    String
  assetLabel   String
  assetUrl     String?
  summary      String
  followUp     String?
  createdAt    DateTime                    @default(now())
  updatedAt    DateTime                    @updatedAt
  question     Question                    @relation(fields: [questionId], references: [id], onDelete: Cascade)
  steps        QuestionExplanationStep[]
}

model QuestionExplanationStep {
  id              Int                  @id @default(autoincrement())
  explanationId   Int
  lineLabel       String
  title           String
  detail          String
  sortOrder       Int
  createdAt       DateTime             @default(now())
  explanation     QuestionExplanation  @relation(fields: [explanationId], references: [id], onDelete: Cascade)

  @@unique([explanationId, sortOrder])
}

model Homework {
  id        Int      @id @default(autoincrement())
  studentId Int
  lessonId  String?
  title     String
  status    String
  score     Int?
  content   String?
  teacherNote String?
  dateLabel String
  createdAt DateTime @default(now())
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  lesson    Lesson?  @relation(fields: [lessonId], references: [id], onDelete: SetNull)
}

model Message {
  id        Int      @id @default(autoincrement())
  studentId Int
  channel   String
  fromRole  String
  title     String
  body      String
  timeLabel String
  createdAt DateTime @default(now())
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
}
